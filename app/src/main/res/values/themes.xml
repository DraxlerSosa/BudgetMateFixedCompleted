<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.BudgetMate" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryVariant">@color/navy_primary</item>
        <item name="colorOnPrimary">@color/navy_dark</item>
        <item name="colorSecondary">@color/navy_primary</item>
        <item name="colorSecondaryVariant">@color/navy_dark</item>
        <item name="colorOnSecondary">@color/surface_white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface_white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor" tools:targetApi="21">@color/navy_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <!-- Splash screen theme — full screen, no action bar, dark status bar -->
    <style name="Theme.BudgetMate.Splash" parent="Theme.BudgetMate">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/navy_primary</item>
        <item name="android:statusBarColor" tools:targetApi="21">@color/navy_primary</item>
    </style>

    <!-- Consistent card style used across all screens -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_marginBottom">0dp</item>
    </style>

    <!-- Primary filled button -->
    <style name="ButtonPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/teal_primary</item>
        <item name="android:textColor">@color/navy_dark</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
